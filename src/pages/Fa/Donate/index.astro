---
import FaLayout from "../../../layouts/FaLayout.astro";


---


<FaLayout title="Support Ermia M. Codev ~ Donation" keywrd="Ermia,Moghadamy,Codev,Donate">
    <div x-data="{copy2Clip(txt) {navigator.clipboard.writeText(txt);}}" class="flex flex-col gap-y-16">

        <div class="bg-slate-700 max-w-6xl container mx-auto px-6 py-6 rounded-2xl shadow">
            <div class="w-full flex flex-col lg:flex-row items-center gap-x-8 gap-y-8">
                <div>
                    <img class="p-2 bg-white rounded-2xl shadow w-auto max-h-48" src="/assets/wallets/BTC.png"
                        alt="0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC">
                </div>
                <div class="flex flex-col py-2 gap-y-4">
                    <div class="inline-flex gap-1.5 items-center">
                        <img class="bg-white rounded-full p-1 bg w-12 h-12" src="/assets/icons/BTC.png" alt="">
                        <h2 class="font-bold text-2xl xl:text-3xl">Bitcoin</h2>
                    </div>
                    <div>
                        <div class="mt-3 flex items-center p-4 mb-4 text-yellow-800 rounded-lg bg-yellow-50 dark:bg-gray-800 dark:text-yellow-300"
                            role="alert">
                            <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor" viewBox="0 0 20 20">
                                <path
                                    d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z" />
                            </svg>
                            <span class="sr-only">Info</span>
                            <div class="ms-3 text-sm font-medium">
                                Only Send Assets Via <a class="underline font-semibold" href="">BTC</a> Network
                            </div>
                        </div>

                    </div>
                    <input x-ref="btcCard"
                        @click="copy2Clip('bc1qglnnaj65exeza4eulm99qe6as40mf034pejc6s');$refs.btcCard.focus()"
                        class="cursor-pointer border-2 text-base rounded-lg focus:border-teal-500 block w-full p-2.5 bg-gray-700 border-gray-600 placeholder-gray-400 text-teal-50 focus:ring-teal-300 focus:border-teal-500 outline-none"
                        value="bc1qglnnaj65exeza4eulm99qe6as40mf034pejc6s" readonly />
                </div>

                <div class="lg:flex-grow flex flex-row justify-end">
                    <div class="flex flex-col gap-4">
                        <a target="_blank" href="https://trustwallet.com/"
                            class="text-gray-900 bg-gray-100 hover:bg-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 inline-flex gap-3 items-center dark:focus:ring-gray-500 me-2 mb-2">
                            <img class=" w-6 h-6" alt="Trust" src="/assets/icons/trust.webp">
                            Open TrustWallet
                        </a>
                        <a target="_blank" href="https://btc.com" class="text-white bg-[#FF9119] hover:bg-[#FF9119]/80 focus:ring-4 focus:outline-none focus:ring-[#FF9119]/50 font-semibold rounded-lg text-base px-5 py-2.5 text-center inline-flex items-center dark:hover:bg-[#FF9119]/80 dark:focus:ring-[#FF9119]/40 me-2 mb-2">
                            <svg class="w-6 h-6 me-2 -ms-1" aria-hidden="true" focusable="false" data-prefix="fab"
                                data-icon="bitcoin" role="img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
                                <path fill="currentColor"
                                    d="M504 256c0 136.1-111 248-248 248S8 392.1 8 256 119 8 256 8s248 111 248 248zm-141.7-35.33c4.937-32.1-20.19-50.74-54.55-62.57l11.15-44.7-27.21-6.781-10.85 43.52c-7.154-1.783-14.5-3.464-21.8-5.13l10.93-43.81-27.2-6.781-11.15 44.69c-5.922-1.349-11.73-2.682-17.38-4.084l.031-.14-37.53-9.37-7.239 29.06s20.19 4.627 19.76 4.913c11.02 2.751 13.01 10.04 12.68 15.82l-12.7 50.92c.76 .194 1.744 .473 2.829 .907-.907-.225-1.876-.473-2.876-.713l-17.8 71.34c-1.349 3.348-4.767 8.37-12.47 6.464 .271 .395-19.78-4.937-19.78-4.937l-13.51 31.15 35.41 8.827c6.588 1.651 13.05 3.379 19.4 5.006l-11.26 45.21 27.18 6.781 11.15-44.73a1038 1038 0 0 0 21.69 5.627l-11.11 44.52 27.21 6.781 11.26-45.13c46.4 8.781 81.3 5.239 95.99-36.73 11.84-33.79-.589-53.28-25-65.99 17.78-4.098 31.17-15.79 34.75-39.95zm-62.18 87.18c-8.41 33.79-65.31 15.52-83.75 10.94l14.94-59.9c18.45 4.603 77.6 13.72 68.81 48.96zm8.417-87.67c-7.673 30.74-55.03 15.12-70.39 11.29l13.55-54.33c15.36 3.828 64.84 10.97 56.85 43.03z">
                                </path>
                            </svg>
                            Pay with Bitcoin
                        </a>
                    </div>
                </div>
            </div>
        </div>


        <div class="bg-slate-700 max-w-6xl container mx-auto px-6 py-6 rounded-2xl shadow">
            <div class="w-full flex flex-col lg:flex-row items-center gap-x-8 gap-y-8">
                <div>
                    <img class="p-2 bg-white rounded-2xl shadow w-auto max-h-48" src="/assets/wallets/Ethereum.png"
                        alt="0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC">
                </div>
                <div class="flex flex-col py-2 gap-y-4">
                    <div class="inline-flex gap-1.5 items-center">
                        <img class="bg-white rounded-full p-1 w-12 h-12" src="/assets/icons/ETH.png" alt="">
                        <h2 class="font-bold text-2xl xl:text-3xl">Ethereum</h2>
                    </div>
                    <div>
                        <div class="mt-3 flex items-center p-4 mb-4 text-yellow-800 rounded-lg bg-yellow-50 dark:bg-gray-800 dark:text-yellow-300"
                            role="alert">
                            <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor" viewBox="0 0 20 20">
                                <path
                                    d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z" />
                            </svg>
                            <span class="sr-only">Info</span>
                            <div class="ms-3 text-sm font-medium">
                                Only Send Assets Via <a class="underline font-semibold" href="">Ethereum MainNet</a>
                            </div>
                        </div>

                    </div>
                    <input x-ref="ethCard"
                        @click="copy2Clip('0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC');$refs.ethCard.focus()"
                        class="cursor-pointer border-2 text-base rounded-lg focus:border-teal-500 block w-full p-2.5 bg-gray-700 border-gray-600 placeholder-gray-400 text-teal-50 focus:ring-teal-300 focus:border-teal-500 outline-none"
                        value="0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC" readonly />
                </div>

                <div class="lg:flex-grow flex flex-row justify-end">
                    <div class="flex flex-col gap-4">
                        <a target="_blank" href="https://metamask.io"
                            class="text-gray-900 bg-white hover:bg-gray-100 border border-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 text-center inline-flex items-center dark:focus:ring-gray-600 dark:bg-gray-800 dark:border-gray-700 dark:text-white dark:hover:bg-gray-700 me-2 mb-2">
                            <img class="w-6 h-6 me-2" src="/assets/icons/METAMASK.svg" alt="">
                            Open MetaMask
                        </a>
                        <a target="_blank" href="https://trustwallet.com/"
                            class="text-gray-900 bg-gray-100 hover:bg-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 inline-flex gap-3 items-center dark:focus:ring-gray-500 me-2 mb-2">
                            <img class=" w-6 h-6" alt="Trust" src="/assets/icons/trust.webp">
                            Open TrustWallet
                        </a>
                        <a target="_blank" href="https://ethereum.org"
                            class="text-gray-900 bg-gray-100 hover:bg-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 text-center inline-flex items-center dark:focus:ring-gray-500 me-2 mb-2">
                            <svg class="w-4 h-4 me-2 -ms-1 text-[#626890]" aria-hidden="true" focusable="false"
                                data-prefix="fab" data-icon="ethereum" role="img" xmlns="http://www.w3.org/2000/svg"
                                viewBox="0 0 320 512">
                                <path fill="currentColor"
                                    d="M311.9 260.8L160 353.6 8 260.8 160 0l151.9 260.8zM160 383.4L8 290.6 160 512l152-221.4-152 92.8z">
                                </path>
                            </svg>
                            Pay with Ethereum
                        </a>
                    </div>
                </div>
            </div>
        </div>


        <div class="bg-slate-700 max-w-6xl container mx-auto px-6 py-6 rounded-2xl shadow">
            <div class="w-full flex flex-col lg:flex-row items-center gap-x-8 gap-y-8">
                <div>
                    <img class="p-2 bg-white rounded-2xl shadow w-auto max-h-48" src="/assets/wallets/Polygon.png"
                        alt="0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC">
                </div>
                <div class="flex flex-col py-2 gap-y-4">
                    <div class="inline-flex gap-1.5 items-center">
                        <img class="bg-white rounded-full p-1 w-12 h-12" src="/assets/icons/polygon.webp" alt="">
                        <h2 class="font-bold text-2xl xl:text-3xl">Polygon (MATIC)</h2>
                    </div>
                    <div>
                        <div class="mt-3 flex items-center p-4 mb-4 text-yellow-800 rounded-lg bg-yellow-50 dark:bg-gray-800 dark:text-yellow-300"
                            role="alert">
                            <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor" viewBox="0 0 20 20">
                                <path
                                    d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z" />
                            </svg>
                            <span class="sr-only">Info</span>
                            <div class="ms-3 text-sm font-medium">
                                Only Send Assets Via <a class="underline font-semibold" href="">Polygon</a> Network
                            </div>
                        </div>

                    </div>
                    <input x-ref="plgCard"
                        @click="copy2Clip('0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC');$refs.plg.focus()"
                        class="cursor-pointer border-2 text-base rounded-lg focus:border-teal-500 block w-full p-2.5 bg-gray-700 border-gray-600 placeholder-gray-400 text-teal-50 focus:ring-teal-300 focus:border-teal-500 outline-none"
                        value="0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC" readonly />
                </div>

                <div class="lg:flex-grow flex flex-row justify-end">
                    <div class="flex flex-col gap-4">
                        <a target="_blank" href="https://metamask.io"
                            class="text-gray-900 bg-white hover:bg-gray-100 border border-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 text-center inline-flex items-center dark:focus:ring-gray-600 dark:bg-gray-800 dark:border-gray-700 dark:text-white dark:hover:bg-gray-700 me-2 mb-2">
                            <img class="w-6 h-6 me-2" src="/assets/icons/METAMASK.svg" alt="">
                            Open MetaMask
                        </a>
                        <a target="_blank" href="https://trustwallet.com/"
                            class="text-gray-900 bg-gray-100 hover:bg-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 inline-flex gap-3 items-center dark:focus:ring-gray-500 me-2 mb-2">
                            <img class=" w-6 h-6" alt="Trust" src="/assets/icons/trust.webp">
                            Open TrustWallet
                        </a>
                        <a target="_blank" href="https://polygon.technology/"
                            class="text-gray-900 bg-gray-100 hover:bg-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 text-center inline-flex items-center dark:focus:ring-gray-500 me-2 mb-2">
                            <img class="w-6 h-6 me-2" src="/assets/icons/polygon.webp" alt="">

                            Pay with Polygon
                        </a>
                    </div>
                </div>
            </div>
        </div>


        <div class="bg-slate-700 max-w-6xl container mx-auto px-6 py-6 rounded-2xl shadow">
            <div class="w-full flex flex-col lg:flex-row items-center gap-x-8 gap-y-8">
                <div>
                    <img class="p-0 bg-white rounded-2xl shadow w-auto max-h-48" src="/assets/wallets/Monero.png"
                        alt="0xE9fEa228B3538f66Dd5D300Ec9FD48A48034A7FC">
                </div>
                <div class="flex flex-col py-2 gap-y-4">
                    <div class="inline-flex gap-1.5 items-center">
                        <img class="bg-white rounded-full p-1 w-12 h-12" src="/assets/icons/XMR.png" alt="">
                        <h2 class="font-bold text-2xl xl:text-3xl">Monero (XMR)</h2>
                    </div>
                    <div>
                        <div class="mt-3 flex items-center p-4 mb-4 text-yellow-800 rounded-lg bg-yellow-50 dark:bg-gray-800 dark:text-yellow-300"
                            role="alert">
                            <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg"
                                fill="currentColor" viewBox="0 0 20 20">
                                <path
                                    d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z" />
                            </svg>
                            <span class="sr-only">Info</span>
                            <div class="ms-3 text-sm font-medium">
                                Only Send Assets Via <a class="underline font-semibold" href="">XMR</a> Network
                            </div>
                        </div>

                    </div>
                    <input x-ref="xmrCard"
                        @click="copy2Clip('46FSrmpmTQYb8MZ6o3dCF5GotBsujCfLZLBk59rW7C79GnZcx4Nykm3aHbBbXHVTx1Dr58tZ7Ewvu4GvHqnV9jqVAETdBmw');$refs.xmrCard.focus()"
                        class="cursor-pointer border-2 text-base rounded-lg focus:border-teal-500 block w-full p-2.5 bg-gray-700 border-gray-600 placeholder-gray-400 text-teal-50 focus:ring-teal-300 focus:border-teal-500 outline-none"
                        value="46FSrmpmTQYb8MZ6o3dCF5GotBsujCfLZLBk59rW7C79GnZcx4Nykm3aHbBbXHVTx1Dr58tZ7Ewvu4GvHqnV9jqVAETdBmw" readonly />
                </div>

                <div class="lg:flex-grow flex flex-row justify-end">
                    <div class="flex flex-col gap-4">
                        <a target="_blank" href="https://getmonero.org"
                            class="text-gray-900 bg-gray-100 hover:bg-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 text-center inline-flex items-center dark:focus:ring-gray-500 me-2 mb-2">
                            <img class="w-6 h-6 me-2" src="/assets/icons/XMR.png" alt="">
                            Pay With Monero
                        </a>
                        <a target="_blank" href="https://cakewallet.com/"
                            class="text-gray-900 bg-gray-100 hover:bg-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 inline-flex gap-3 items-center dark:focus:ring-gray-500 me-2 mb-2">
                            <img class=" w-6 h-6" alt="Trust" src="/assets/icons/CAKE.png">
                            Cake Wallet 
                        </a>
                        <a target="_blank" href="https://mymonero.com/"
                            class="text-gray-900 bg-white hover:bg-gray-100 border border-gray-200 focus:ring-4 focus:outline-none focus:ring-gray-100 font-semibold rounded-lg text-base px-5 py-2.5 text-center inline-flex items-center dark:focus:ring-gray-600 dark:bg-gray-800 dark:border-gray-700 dark:text-white dark:hover:bg-gray-700 me-2 mb-2">
                            <img class="w-6 h-6 me-2" src="/assets/icons/MyMon.png" alt="">
                            MyMonero
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</FaLayout>